# ============================================
# AMAZON MQ DEMO - ENVIRONMENT VARIABLES
# ============================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual credentials
# 3. Never commit .env to git (it contains secrets!)
#
# Command: cp .env.example .env
# ============================================

# --------------------------------------------
# AMAZON MQ (RabbitMQ) CONNECTION
# --------------------------------------------
# Get these values from AWS Console → Amazon MQ → Your Broker

# The broker endpoint URL (without protocol)
# Example: b-1234abcd-5678-efgh-ijkl-9012mnopqrst.mq.us-east-1.amazonaws.com
RABBITMQ_HOST=your-broker-id.mq.us-east-1.amazonaws.com

# Port for AMQPS (SSL) connection
# Amazon MQ RabbitMQ always uses SSL on port 5671
RABBITMQ_PORT=5671

# Username you created when setting up the broker
RABBITMQ_USERNAME=admin

# Password you created when setting up the broker
# Use a strong password with special characters!
RABBITMQ_PASSWORD=YourSecurePassword123!

# Virtual host (default is /)
RABBITMQ_VHOST=/

# --------------------------------------------
# QUEUE CONFIGURATION
# --------------------------------------------
# Name of the queue for order messages
QUEUE_NAME=orders

# Name of the dead letter queue for failed messages
DLQ_NAME=orders.dlq

# --------------------------------------------
# FLASK API CONFIGURATION
# --------------------------------------------
# Port for the Flask API server
API_PORT=5000

# Debug mode (set to False in production)
FLASK_DEBUG=True

# --------------------------------------------
# OPTIONAL: LOCAL RABBITMQ (for testing without AWS)
# --------------------------------------------
# Uncomment these and comment out the Amazon MQ settings above
# to test locally with Docker RabbitMQ

# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USERNAME=guest
# RABBITMQ_PASSWORD=guest
